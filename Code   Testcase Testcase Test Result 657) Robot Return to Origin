class Solution(object):
    def judgeCircle(self, moves):
        r=0
        u=0
        for i in range(0,len(moves)):
            if moves[i]=='U':
                u=u+1
            elif moves[i]=='D':
                u=u-1
            elif moves[i]=='R':
                r=r+1
            elif moves[i]=='L':
                r=r-1
        if r==0 and u==0:
            return True
        else:
            return False
        
